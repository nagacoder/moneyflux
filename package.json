{
  "name": "moneyflux",
  "version": "0.1.0",
  "private": true,
  "author": {
    "name": "nagacoer",
    "email": "nagacoder@outlook.com"
  },
  "engines": {
    "node": ">= 14.18.0 <=16.00.0",
    "yarn": ">= 1.22.00"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prepare": "husky install",
    "format": "prettier --write --ignore-unknown",
    "codegen": "graphql-codegen --config graphql.config.yaml --errors-only"
  },
  "prettier": {
    "endOfLine": "auto",
    "printWidth": 120,
    "semi": true,
    "singleQuote": false,
    "trailingComma": "all"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  },
  "dependencies": {
    "@chakra-ui/react": "^2.4.1",
    "@emotion/react": "^11",
    "@emotion/styled": "^11",
    "@graphql-codegen/cli": "^2.13.12",
    "@graphql-codegen/typescript-operations": "^2.5.7",
    "@graphql-codegen/typescript-react-query": "^4.0.5",
    "@tanstack/react-query": "^4.16.1",
    "@types/node": "18.11.9",
    "@types/react": "18.0.25",
    "@types/react-dom": "18.0.9",
    "cross-env": "^7.0.3",
    "eslint": "8.28.0",
    "eslint-config-next": "13.0.4",
    "framer-motion": "^6",
    "graphql": "^16.6.0",
    "graphql-tag": "^2.12.6",
    "next": "13.0.4",
    "prettier": "^2.7.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "typescript": "4.9.3"
  },
  "devDependencies": {
    "husky": "^8.0.2",
    "lint-staged": "^13.0.3"
  }
}
